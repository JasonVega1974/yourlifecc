{
  "rewrites": [
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/podcasts.html", "destination": "/app/podcasts.html" },
    { "source": "/app/calendar.html", "destination": "/app/calendar.html" },
    { "source": "/app/(.*)", "destination": "/app/index.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/faith", "destination": "/faith.html" },
    { "source": "/return", "destination": "/return.html" },
    { "source": "/unsubscribe", "destination": "/unsubscribe.html" },
    { "source": "/prayer/:id", "destination": "/api/prayer-share?id=:id" }
  ],
  "crons": [
    { "path": "/api/cron/weekly-digest",   "schedule": "0 * * * 0,1" },
    { "path": "/api/cron/engagement-tick", "schedule": "0 * * * *" },
    { "path": "/api/cron/crossover-tick",  "schedule": "0 10 * * 3" },
    { "path": "/api/cron/push-tick",       "schedule": "0 * * * *" }
  ],
  "functions": {
    "api/cron/crossover-tick.js": {
      "includeFiles": "docs/crossover-highlights.md"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://translate.googleapis.com https://translate.google.com https://challenges.cloudflare.com https://js.sentry-cdn.com https://client.crisp.chat https://js.stripe.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://translate.googleapis.com https://translate.google.com https://bible-api.com https://client.crisp.chat wss://client.relay.crisp.chat https://*.sentry.io; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com data:; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://challenges.cloudflare.com https://js.stripe.com https://hooks.stripe.com; media-src 'self' blob: https://*.supabase.co; object-src 'none'; base-uri 'self'; form-action 'self' https://buy.stripe.com https://billing.stripe.com; frame-ancestors 'self'; worker-src 'self'; manifest-src 'self'" }
      ]
    },
    {
      "source": "/(login|register-faith|register|reset-password|set-password|activate|confirm|onboard|admin|account|app-bridge)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/unsubscribe.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag",  "value": "noindex, nofollow" }
      ]
    }
  ]
}
