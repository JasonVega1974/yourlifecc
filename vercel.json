{
  "rewrites": [
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/podcasts.html", "destination": "/app/podcasts.html" },
    { "source": "/app/calendar.html", "destination": "/app/calendar.html" },
    { "source": "/app/(.*)", "destination": "/app/index.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/faith", "destination": "/faith.html" },
    { "source": "/return", "destination": "/return.html" },
    { "source": "/unsubscribe", "destination": "/unsubscribe.html" },
    { "source": "/prayer/:id", "destination": "/api/prayer-share?id=:id" }
  ],
  "crons": [
    { "path": "/api/cron/weekly-digest",   "schedule": "0 * * * 0,1" },
    { "path": "/api/cron/engagement-tick", "schedule": "0 * * * *" },
    { "path": "/api/cron/crossover-tick",  "schedule": "0 10 * * 3" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
      ]
    },
    {
      "source": "/(login|register-faith|register|reset-password|set-password|activate|confirm|onboard|admin|account|app-bridge)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/unsubscribe.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag",  "value": "noindex, nofollow" }
      ]
    }
  ]
}
